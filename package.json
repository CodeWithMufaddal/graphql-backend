{
  "name": "graphql-backend",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL backend starter with Express, PostgreSQL, Sequelize, and simple JWT auth.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run",
    "db:migrate": "tsx src/db/scripts/migrate.ts up",
    "db:migrate:undo": "tsx src/db/scripts/migrate.ts down",
    "db:seed": "tsx src/db/scripts/seed.ts up",
    "db:seed:undo": "tsx src/db/scripts/seed.ts down",
    "db:setup": "npm run db:migrate && npm run db:seed"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.25",
    "bcryptjs": "^3.0.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^5.1.0",
    "express-graphql": "^0.12.0",
    "graphql": "^16.11.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "pg": "^8.16.3",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.7",
    "umzug": "^3.8.2",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.7.2",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.6.2",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  }
}

