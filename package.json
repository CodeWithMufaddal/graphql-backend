{
  "name": "graphql-backend",
  "version": "1.0.0",
  "private": true,
  "description": "GraphQL backend starter with Express, PostgreSQL, Sequelize, and simple JWT auth.",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "test": "vitest run --dir tests --pool threads",
    "db:check": "tsx src/db/scripts/check.ts",
    "db:migrate": "tsx src/db/scripts/migrate.ts up",
    "db:migrate:undo": "tsx src/db/scripts/migrate.ts down",
    "db:seed": "tsx src/db/scripts/seed.ts up",
    "db:seed:undo": "tsx src/db/scripts/seed.ts down",
    "db:setup": "npm run db:migrate && npm run db:seed",
    "gen:module": "node scripts/gen_graphql_module.js"
  },
  "dependencies": {
    "@graphql-tools/schema": "^10.0.32",
    "bcryptjs": "^3.0.3",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.21.2",
    "graphql": "^16.11.0",
    "graphql-http": "^1.22.4",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "morgan": "^1.10.1",
    "pg": "^8.20.0",
    "pg-hstore": "^2.3.4",
    "prom-client": "^15.1.3",
    "sequelize": "^6.37.8",
    "umzug": "^3.8.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.58.2",
    "@typescript-eslint/parser": "^8.58.2",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
